#. These strings are extracted for translation
#: src/data_translations.vala:6
msgid ""
"Fonts without decorative strokes; clean and modern, commonly used for UI and "
"body text."
msgstr ""
"Fontovi bez ukrasnih poteza; čist i moderan, često korišten za korisničko "
"sučelje i tekst sadržaja."

#: src/data_translations.vala:7
msgid ""
"Decorative fonts designed for headlines and large sizes, not suitable for "
"long text."
msgstr ""
"Dekorativni fontovi namijenjeni naslovima i velikim veličinama. Nisu "
"prikladni za dugačak tekst."

#: src/data_translations.vala:8
msgid ""
"Fonts with decorative strokes at the ends of letters; traditional and often "
"used in print."
msgstr ""
"Fontovi s ukrasnim potezima na krajevima slova; tradicionalno i često "
"korišteno u tisku."

#: src/data_translations.vala:9
msgid ""
"Fonts that mimic handwritten or cursive styles; informal and expressive."
msgstr ""
"Fontovi koji oponašaju rukopisne ili kurzivne stilove; neformalno i "
"izražajno."

#: src/data_translations.vala:10
msgid ""
"Fonts where all characters have equal width; commonly used for code and "
"terminals."
msgstr ""
"Fontovi u kojima su svi znakovi jednake širine; Često se koristi za "
"programski kod i terminale."

#: src/data_translations.vala:11
msgid ""
"Symbol-based fonts containing pictograms or UI icons instead of letters."
msgstr ""
"Fontovi temeljeni na simbolima koji sadrže piktograme ili ikone za "
"korisničko sučelje umjesto slova."

#: src/data_translations.vala:12
msgid ""
"Permissive licence allowing almost unrestricted use, modification, and "
"distribution."
msgstr ""
"Permisivna licenca dopušta gotovo neograničenu upotrebu, mijenjanje i "
"distribuciju."

#: src/data_translations.vala:13
msgid ""
"Free to use, modify, and distribute, with conditions: no selling and "
"original licence must be included."
msgstr ""
"Slobodno korištenje, mijenjanje i distribucija, uz uvjete: ne smije se "
"prodavati i originalna licenca se mora uključiti."

#: src/data_translations.vala:14
msgid ""
"Permissive, requires attribution, notice of changes, and inclusion of NOTICE "
"file. Modified code can use a different licence."
msgstr ""
"Permisivno, zahtijeva navođenje izvora, obavijest o promjenama i "
"uključivanje datoteke OBAVIJESTI. Promijenjeni kod može koristiti jednu "
"drugu licencu."

#: src/data_translations.vala:15
msgid "Permissive, requires attribution and licence file."
msgstr "Permisivno, zahtijeva navođenje izvora i datoteku licence."

#: src/data_translations.vala:16 src/data_translations.vala:17
msgid ""
"Permissive license allowing unrestricted use, modification, and distribution."
msgstr ""
"Permisivna licenca koja dopušta neograničenu upotrebu, mijenjanje i "
"distribuciju."

