msgstr "Fontovi;Instaliraj;"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:7 src/window.blp:5
#: src/window.blp:27
msgid "Sitra"
msgstr "Sitra"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:10
msgid ""
"Get your fonts from online sources with a sleek, friendly user interface. "
"Sitra provides a seamless experience for installing, uninstalling and "
"previewing fonts."
msgstr ""
"Preuzmite fontove s internetskih izvora uz elegantno i prijateljsko "
"korisničko sučelje. Sitra pruža besprijekorno iskustvo instalacije, "
"deinstalacije i pregleda fontova."

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:15
msgid "List fonts available on Google Fonts"
msgstr "Prikaz popisa fontova koji su dostupni na Google Fonts"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:16
msgid "Preview the fonts using Fontsource CDN for privacy"
msgstr "Pregled fontova koristeći Fontsource CDN za privatnost"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:17
msgid ""
"Get code to use the font in your project, via CDN or npm from fontsource"
msgstr ""
"Preuzimanje koda za korištenje fonta u svom projektu, putem CDN-a ili NPM-a "
"iz fontsource-a"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:18
msgid "Download the fonts on your device in ttf format from google"
msgstr "Preuzimanje fontova na svoj uređaj u ttf formatu s Googlea"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:19
msgid ""
"Filter font by category using the toggle buttons or by family and subset "
"using search"
msgstr ""
"Filtriranje fonta po kategoriji pomoću tipki za uključivanje/isključivanje "
"ili po obitelji i podskupu koristeći pretragu"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:24
msgid "Ronnie Nissan"
msgstr "Ronnie Nissan"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:44
msgid "Showcasing font preview"
msgstr "Prikaz pregleda fonta"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:48
msgid "Showcasing font preview when a font is already installed"
msgstr "Prikaz pregleda fonta kada je font već instaliran"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:52
msgid "Showcasing font preview with different subsets, Arabic in this case"
msgstr ""
"Prikaz pregleda fonta s različitim podskupovima, u ovom slučaju arapski"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:56
msgid "Showcasing Use in an Project dialog, showing npm instructions"
msgstr "Prikaz dijaloga „Koristi u projektu“, prikazuju se npm upute"

#: data/io.github.ronniedroid.sitra.metainfo.xml.in:60
msgid "Showcasing Use in an Project dialog, showing cdn instructions"
msgstr "Prikaz dijaloga „Koristi u projektu“, prikazuju se cdn upute"

#: src/application.vala:52
msgid "Sitra helps you install fonts from online sources on your system"
msgstr "Sitra pomaže instalirati fontove s online izvora na vaš sustav"

#: src/application.vala:58
msgid "translator-credits"
msgstr "Milo Ivir <mail@milotype.de>, 2026"

