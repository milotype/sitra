#: data/io.github.ronniedroid.sitra.desktop.in:3
#: data/io.github.ronniedroid.sitra.metainfo.xml.in:8
msgid "Get fonts from online sources"
msgstr "Preuzimanje fontova s internetskih izvora"

#: data/io.github.ronniedroid.sitra.desktop.in:9
